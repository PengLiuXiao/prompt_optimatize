# === Prompt Optimizer 模型配置 ===
# 复制此文件为 .env，填入你的真实值：
#   cp skills/prompt-optimizer/assets/.env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到 git。

# API Key（必填）
# 填入你使用的模型服务商对应的 key
# 支持：DeepSeek / OpenAI / Anthropic / 通义千问(DashScope) 等
#
# 根据你使用的服务商，取消注释并填写对应的一行：
# DEEPSEEK_API_KEY=sk-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# DASHSCOPE_API_KEY=sk-your-key-here

# 目标模型名（可选，也可在运行时通过 --model 指定）
# 示例：deepseek/deepseek-chat-v4, gpt-4o, claude-sonnet-4-20250514, qwen-plus
# TARGET_MODEL=deepseek/deepseek-chat-v4

# 自定义 API 地址（可选）
# 仅在使用第三方中转、公司内部 gateway 或本地部署模型时需要填写
# 使用官方 API 时无需设置
# TARGET_BASE_URL=https://api.deepseek.com
